# MongoDB Connection String
# For local development use: mongodb://127.0.0.1:27017/ecommerce
# For production, use your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ecommerce?retryWrites=true&w=majority

# JWT Secret Key (use a strong random string)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Server Port (default: 5000)
PORT=5000

